# ─── AI Services ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
DEEPGRAM_API_KEY=...          # used for both STT (nova-3) and TTS (aura)

# Optional — ElevenLabs TTS (better Bangla voices)
# ELEVENLABS_API_KEY=...
# ELEVENLABS_VOICE_ID=...

# Optional — Cartesia TTS
# CARTESIA_API_KEY=...

# ─── Alpha PBX (connektstudio) credentials ────────────────────────────────────
# From your Alpha PBX welcome email:
PBX_SIP_SERVER=connektstudio.alphapbx.net  # SIP registrar hostname
PBX_SIP_PORT_UDP=8090                      # UDP/TCP port
PBX_SIP_PORT_TLS=8091                      # TLS port (recommended)
PBX_IP_NUMBER=09647664295                  # Your Alpha PBX IP number (DID)
PBX_DID_NUMBER=+8809647664295             # E.164 format for outbound caller ID

# Extension to use for the AI bot (pick one of 101-105)
PBX_EXTENSION=101
PBX_EXTENSION_PASSWORD=TFbY47W4tP8Jg4

# All extensions & passwords (for reference / multi-agent setups):
# 101 → TFbY47W4tP8Jg4
# 102 → J7gm54zM73xgG
# 103 → 6AhqGvMaSJksD
# 104 → 7vJLwHUZ6sPsE
# 105 → Na2LEbM9ae4FC

# ─── Asterisk AMI (for outbound calls) ────────────────────────────────────────
AMI_HOST=127.0.0.1
AMI_PORT=5038
AMI_USERNAME=pipecat
AMI_SECRET=pipecat_secret               # must match manager.conf

# ─── Server ────────────────────────────────────────────────────────────────────
PORT=7860                                # FastAPI server port

# ─── Optional: Twilio (only if using Twilio as the SIP-WebSocket bridge) ───────
# TWILIO_ACCOUNT_SID=AC...
# TWILIO_AUTH_TOKEN=...
